<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wellesley Spots</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include ('navbar') %>

    <main>
        <h1>Profile</h1>
        <div class="profile-container">
            <h2>User Information</h2>
            <p><strong>Name:</strong> <span id="profileName"><%= username || 'Not logged in' %></span></p>
            <p><strong>Email:</strong> <span id="profileEmail"><%= email || 'Not logged in' %></span></p>
            <a href="/collections">Go to My Collections</a>
        </div>
    </main>
</body>
</html>
