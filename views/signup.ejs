<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wellesley Spots</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include ('navbar') %>

  <main>
    <h1>Account Access</h1>

    <% if (flashError && flashError.length) { %>
      <p class="message message-error"><%= flashError[0] %></p>
    <% } %>
    <% if (flashInfo && flashInfo.length) { %>
      <p class="message message-success"><%= flashInfo[0] %></p>
    <% } %>

    <div class="auth-grid">
      <section class="signup-container">
        <h2>Create Account</h2>
        <form id="signupForm" method="POST" action="/register">
          <p><label for="username">Username:</label>
          <input type="text" id="username" name="username" required></p>

          <p><label for="email">Email:</label>
          <input type="email" id="email" name="email" required pattern="^[^\s@]+@wellesley\.edu$" title="Use your @wellesley.edu email address" autocomplete="email"></p>
          <p class="hint">Wellesley email only: your address must end with @wellesley.edu. use test@wellesley.edu for now</p>

          <p><label for="password">Password:</label>
          <input type="password" id="password" name="password" required></p>

          <button type="submit">Sign Up</button>
        </form>
      </section>

      <section class="signup-container">
        <h2>Login</h2>
        <form id="loginForm" method="POST" action="/login">
          <p><label for="loginIdentifier">Username or Email:</label>
          <input type="text" id="loginIdentifier" name="loginIdentifier" required></p>

          <p><label for="loginPassword">Password:</label>
          <input type="password" id="loginPassword" name="password" required></p>

          <button type="submit">Login</button>
        </form>
      </section>
    </div>

  </main>
</body>
</html>
