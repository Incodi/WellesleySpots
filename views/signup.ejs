<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wellesley Spots</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include ('navbar') %>

  <main class="page auth-page">
    <h1>Account Access</h1>

    <% if (flashError && flashError.length) { %>
      <p class="message message-error"><%= flashError[0] %></p>
    <% } %>
    <% if (flashInfo && flashInfo.length) { %>
      <p class="message message-success"><%= flashInfo[0] %></p>
    <% } %>

    <div class="auth-grid">
      <section class="signup-container">
        <h2>Create Account</h2>
        <form id="signupForm" method="POST" action="/register">
          <label for="username">Username:</label>
          <input type="text" id="username" name="username" required>

          <label for="password">Password:</label>
          <input type="password" id="password" name="password" required>

          <button type="submit">Sign Up</button>
        </form>
      </section>

      <section class="signup-container">
        <h2>Login</h2>
        <form id="loginForm" method="POST" action="/login">
          <label for="loginUsername">Username:</label>
          <input type="text" id="loginUsername" name="username" required>

          <label for="loginPassword">Password:</label>
          <input type="password" id="loginPassword" name="password" required>

          <button type="submit">Login</button>
        </form>
      </section>
    </div>

  </main>
</body>
</html>
