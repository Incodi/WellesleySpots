<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - Wellesley Spots</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include ('navbar') %>

    <main>
        <h1>Forgot Password</h1>

        <% if (flashError && flashError.length > 0) { %>
            <div class="message message-error">
                <% flashError.forEach(error => { %>
                    <%= error %><br>
                <% }); %>
            </div>
        <% } %>

        <% if (flashInfo && flashInfo.length > 0) { %>
            <div class="message message-success">
                <% flashInfo.forEach(info => { %>
                    <%= info %><br>
                <% }); %>
            </div>
        <% } %>

        <section class="forgot-password-container">
            <h2>Request a Password Reset</h2>
            <p>Enter your Wellesley email address and we will show a reset confirmation message.</p>

            <form action="/forgot-password" method="post">
                <div class="form-group">
                    <label for="email">Email:</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="name@wellesley.edu"
                        autocomplete="email"
                        required
                    >
                </div>

                <button type="submit">Send Reset Request</button>
            </form>

            <p class="auth-link-row">
                Remembered your password?
                <a href="/signup">Return to login</a>
            </p>
        </section>
    </main>
</body>
</html>