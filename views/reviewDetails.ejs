<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Review Details</title>
    <meta name="author" content="Gloria">
    <link rel="stylesheet" href="/style.css" />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="/review.js"></script>
</head>
<body>
    <%- include ('navbar') %>
    <div id="review">
        <% if (flashError && flashError.length > 0) { %>
            <p class="error"><%= flashError[0] %></p>
        <% } %>
        <% if (flashInfo && flashInfo.length > 0) { %>
            <p class="info"><%= flashInfo[0] %></p>
        <% } %>

        <h1><%= review.title %></h1>
        <h3>By <%= review.username || 'Anonymous' %></h3>

        <p><%= review.likeCount ?? 0 %> Likes</p>
        <form action="/like" method="POST">
            <input type="hidden" name="rr" value="<%= review.rr %>">
            <button type="submit">Like Review</button>
        </form>
        

        <h3>Posted <%= review.createdAt ? new Date(review.createdAt).toLocaleDateString() : 'Unknown date' %></h3>
        <h2>Location</h2>
        <p><%= review.location_name %></p>
        <h2>Rating</h2>
        <p><%= review.rating %> Stars</p>
        <h2>Review</h2>
        <p><%= review.review %></p>
        <h2>Tags</h2>
        <ul>
            <% if (review.tags) { %>
            <% (Array.isArray(review.tags) ? review.tags : [review.tags]).forEach(tag => { %>
                <li><%= tag.trim() %></li>
            <% }) %>
            <% } %>
        </ul>
        <% if (canEdit) { %>
            <button class="click-changes-button">Make Changes</button>
            <form class="delete-review" action="/review/<%= review.rr %>/delete" method="POST">
                <button type="submit" class="delete-button">Delete Review</button>
            </form>
        <% } %>
    </div>

    <% if (canEdit) { %>
        <div class="change-review" style="display: none;">
            <%- include('updateReview') %>
        </div>
    <% } %>
    <div id="comments">
        <%- include ('comments') %>
    </div>
</body>
</html>