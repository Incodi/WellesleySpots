<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Collections</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include ('navbar') %>
    <main>
        <h1>My Collections</h1>
        <section class="profile-container">
            <h2>Reviews</h2>
            <% if (reviews && reviews.length) { %>
                <ul>
                    <% reviews.forEach(function(review) { %>
                        <li>
                            <a href="/review/<%= review.rr %>"><%= review.title %></a> (posted <%= new Date(review.createdAt).toLocaleString() %>)
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="message">No reviews yet.</p>
            <% } %>
        </section>

        <section class="profile-container">
            <h2>Comments</h2>
            <% if (comments && comments.length) { %>
                <ul>
                    <% comments.forEach(function(comment) { %>
                        <li>
                            <% if (comment.rr && comment.comment) { %>
                                <a href="/review/<%= comment.rr %>"><%= comment.comment || 'Comment' %></a>
                            <% } else { %>
                                <%= comment.comment || 'Comment' %>
                            <% } %>
                            <% if (comment.createdAt) { %>
                                (posted <%= new Date(comment.createdAt).toLocaleString() %>)
                            <% } %>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="message">No comments yet.</p>
            <% } %>
        </section>

        <section class="profile-container">
            <h2>Likes</h2>
            <% if (likes && likes.length) { %>
                <ul>
                    <% likes.forEach(function(like) { %>
                        <li>
                            <% const likedLabel = like.title || 'Review cannot be retrieved'; %>
                            <% if (like.rr && like.title) { %>
                                <a href="/review/<%= like.rr %>"><%= likedLabel %></a>
                            <% } else { %>
                                <%= likedLabel %>
                            <% } %>
                            <% if (like.createdAt) { %>
                                (liked <%= new Date(like.createdAt).toLocaleString() %>)
                            <% } %>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="message">No likes yet.</p>
            <% } %>
        </section>

        <section class="profile-container">
            <h2>History</h2>
            <% if (history && history.length) { %>
                <ul>
                    <% history.forEach(function(item) { %>
                        <li>
                            <% const action = item.action || item.type || 'activity'; %>
                            <% let actionLabel = 'Activity'; %>
                            <% if (action === 'review_created') actionLabel = 'Reviewed:'; %>
                            <% if (action === 'review_edited') actionLabel = 'Edited review:'; %>
                            <% if (action === 'review_liked') actionLabel = 'Liked review:'; %>
                            <% if (action === 'review_unliked') actionLabel = 'Removed like from review:'; %>
                            <% const activityLabel = item.title || (item.rr ? ('Review #' + item.rr) : ''); %>
                            <strong><%= actionLabel %></strong>
                            <% if (item.rr) { %>
                                <span><a href="/review/<%= item.rr %>"><%= activityLabel %></a></span>
                            <% } else { %>
                                <span><%= activityLabel %></span>
                            <% } %>
                            <% if (item.createdAt) { %>
                                (<%= new Date(item.createdAt).toLocaleString() %>)
                            <% } %>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="message">No recent activity yet.</p>
            <% } %>
        </section>
    </main>

</body>
</html>
