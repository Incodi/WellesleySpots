<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wellesley Spots</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include ('navbar') %>
    <main>
        <h1>My Collections</h1>

        <section class="profile-container">
            <h2>Reviews</h2>
            <% if (reviews && reviews.length) { %>
                <ul>
                    <% reviews.forEach(function(review) { %>
                        <li>
                            <a href="/review/<%= review.rr %>"><%= review.title %> (posted <%= new Date(review.createdAt).toLocaleString() %>)</a>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="message">No reviews yet.</p>
            <% } %>
        </section>

        <section class="profile-container">
            <h2>Comments</h2>
            <% if (comments && comments.length) { %>
                <ul>
                    <% comments.forEach(function(comment) { %>
                        <li>
                            <strong><%= comment.location_name || comment.title || 'Comment' %></strong>
                            <div><%= comment.comment || comment.text || comment.review || '' %></div>
                            <% if (comment.createdAt) { %>
                                <small>Posted <%= new Date(comment.createdAt).toLocaleString() %></small>
                            <% } %>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="message">No comments yet.</p>
            <% } %>
        </section>

        <section class="profile-container">
            <h2>Likes</h2>
            <% if (likes && likes.length) { %>
                <ul>
                    <% likes.forEach(function(like) { %>
                        <li>
                            <% const likedLabel = like.location_name || like.title || (like.rr ? ('Review #' + like.rr) : 'Liked review'); %>
                            <% if (like.rr) { %>
                                <strong><a href="/review/<%= like.rr %>"><%= likedLabel %></a></strong>
                            <% } else { %>
                                <strong><%= likedLabel %></strong>
                            <% } %>
                            <% if (like.createdAt) { %>
                                <small>Liked <%= new Date(like.createdAt).toLocaleString() %></small>
                            <% } %>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="message">No likes yet.</p>
            <% } %>
        </section>

        <section class="profile-container">
            <h2>History</h2>
            <% if (history && history.length) { %>
                <ul>
                    <% history.forEach(function(item) { %>
                        <li>
                            <% const action = item.action || item.type || 'activity'; %>
                            <% let actionLabel = 'Activity'; %>
                            <% if (action === 'review_created') actionLabel = 'Reviewed'; %>
                            <% if (action === 'review_edited') actionLabel = 'Edited review'; %>
                            <% if (action === 'review_liked') actionLabel = 'Liked review'; %>
                            <% const activityLabel = item.location_name || item.title || (item.rr ? ('Review #' + item.rr) : ''); %>
                            <strong><%= actionLabel %></strong>
                            <% if (item.rr) { %>
                                <span><a href="/review/<%= item.rr %>"><%= activityLabel %></a></span>
                            <% } else { %>
                                <span><%= activityLabel %></span>
                            <% } %>
                            <% if (item.createdAt) { %>
                                <small> - <%= new Date(item.createdAt).toLocaleString() %></small>
                            <% } %>
                        </li>
                    <% }) %>
                </ul>
            <% } else { %>
                <p class="message">No recent activity yet.</p>
            <% } %>
        </section>

    </main>

</body>
</html>
